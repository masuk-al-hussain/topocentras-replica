<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="css/styles.css"/>
    </head>
    <body>
        <!-- Remove header.panel after moving wishlist out -->
        <referenceContainer name="header.panel" remove="true"/>
        
        <!-- Remove default navigation sections -->
        <referenceBlock name="catalog.topnav" remove="true"/>
        <referenceBlock name="store.menu" remove="true"/>
        <referenceContainer name="navigation.sections" remove="true"/>
        
        <!-- Remove Advanced Search link -->
        <referenceBlock name="advanced-search-link" remove="true"/>
        
        <!-- Add custom topbar before default header -->
        <referenceContainer name="header.container">
            <block class="Magento\Framework\View\Element\Template" 
                   name="topocentras.topbar" 
                   template="Magento_Theme::html/topbar.phtml" 
                   before="-"/>
            <block class="Magento\Framework\View\Element\Template" 
                   name="topocentras.main.header" 
                   template="Magento_Theme::html/main-header.phtml" 
                   after="topocentras.topbar">
            </block>
        </referenceContainer>
        
        <!-- Move logo and minicart to main header -->
        <referenceBlock name="logo">
            <arguments>
                <argument name="template" xsi:type="string">Magento_Theme::html/logo.phtml</argument>
            </arguments>
        </referenceBlock>
        <move element="logo" destination="topocentras.main.header" before="-"/>
        <move element="minicart" destination="topocentras.main.header" after="-"/>
        
        <!-- Add custom navigation after header -->
        <referenceContainer name="page.top">
            <block class="Magento\Framework\View\Element\Template" 
                   name="topocentras.navigation" 
                   template="Magento_Theme::html/navigation.phtml"
                   after="header"/>
        </referenceContainer>
    </body>
</page>
