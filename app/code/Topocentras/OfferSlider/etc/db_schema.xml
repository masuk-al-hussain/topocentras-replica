<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <!-- Offer Slider Table -->
    <table name="topocentras_offer_slider" resource="default" engine="innodb" comment="Topocentras Offer Slider Table">
        <column xsi:type="int" name="slider_id" unsigned="true" nullable="false" identity="true" comment="Slider ID"/>
        <column xsi:type="varchar" name="title" nullable="false" length="255" comment="Slider Title"/>
        <column xsi:type="varchar" name="all_offers_link" nullable="true" length="255" comment="All Offers Link"/>
        <column xsi:type="varchar" name="all_offers_text" nullable="true" length="100" default="Visi pasiūlymai" comment="All Offers Link Text"/>
        <column xsi:type="varchar" name="banner_image" nullable="true" length="255" comment="Banner Image"/>
        <column xsi:type="varchar" name="banner_link" nullable="true" length="255" comment="Banner Link"/>
        <column xsi:type="text" name="product_skus" nullable="true" comment="Comma-separated Product SKUs"/>
        <column xsi:type="varchar" name="layout_position" nullable="false" length="10" default="left" comment="Layout Position (left or right)"/>
        <column xsi:type="smallint" name="is_active" unsigned="true" nullable="false" default="1" comment="Is Active"/>
        <column xsi:type="int" name="sort_order" unsigned="true" nullable="false" default="0" comment="Sort Order"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="slider_id"/>
        </constraint>
        <index referenceId="TOPOCENTRAS_OFFER_SLIDER_IS_ACTIVE" indexType="btree">
            <column name="is_active"/>
        </index>
        <index referenceId="TOPOCENTRAS_OFFER_SLIDER_SORT_ORDER" indexType="btree">
            <column name="sort_order"/>
        </index>
    </table>
</schema>
