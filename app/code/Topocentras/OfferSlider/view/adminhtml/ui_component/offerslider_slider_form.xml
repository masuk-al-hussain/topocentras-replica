<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">offerslider_slider_form.offerslider_slider_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Slider Information</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="save" class="Topocentras\OfferSlider\Block\Adminhtml\Slider\Edit\SaveButton"/>
            <button name="delete" class="Topocentras\OfferSlider\Block\Adminhtml\Slider\Edit\DeleteButton"/>
            <button name="back" class="Topocentras\OfferSlider\Block\Adminhtml\Slider\Edit\BackButton"/>
        </buttons>
        <namespace>offerslider_slider_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>offerslider_slider_form.offerslider_slider_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="offerslider_slider_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="offerslider/slider/save"/>
        </settings>
        <dataProvider class="Topocentras\OfferSlider\Model\DataProvider" name="offerslider_slider_form_data_source">
            <settings>
                <requestFieldName>slider_id</requestFieldName>
                <primaryFieldName>slider_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general">
        <settings>
            <label translate="true">General Information</label>
        </settings>
        <field name="slider_id" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">slider</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <dataScope>slider_id</dataScope>
            </settings>
        </field>
        <field name="is_active" sortOrder="10" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">slider</item>
                    <item name="default" xsi:type="number">1</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Enable Slider</label>
                <dataScope>is_active</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="number">0</map>
                            <map name="true" xsi:type="number">1</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
        <field name="title" sortOrder="20" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">slider</item>
                </item>
            </argument>
            <settings>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Slider Title</label>
                <dataScope>title</dataScope>
            </settings>
        </field>
        <field name="all_offers_link" sortOrder="30" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">slider</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">All Offers Link URL</label>
                <dataScope>all_offers_link</dataScope>
            </settings>
        </field>
        <field name="all_offers_text" sortOrder="40" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">slider</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">All Offers Link Text</label>
                <dataScope>all_offers_text</dataScope>
            </settings>
        </field>
        <field name="banner_image" sortOrder="50" formElement="imageUploader">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">slider</item>
                </item>
            </argument>
            <settings>
                <elementTmpl>ui/form/element/uploader/image</elementTmpl>
                <dataType>string</dataType>
                <label translate="true">Banner Image</label>
                <visible>true</visible>
                <required>false</required>
            </settings>
            <formElements>
                <imageUploader>
                    <settings>
                        <required>false</required>
                        <uploaderConfig>
                            <param xsi:type="url" name="url" path="offerslider/slider/upload"/>
                        </uploaderConfig>
                        <previewTmpl>Magento_Catalog/image-preview</previewTmpl>
                        <openDialogTitle>Media Gallery</openDialogTitle>
                        <allowedExtensions>jpg jpeg gif png</allowedExtensions>
                        <maxFileSize>4194304</maxFileSize>
                    </settings>
                </imageUploader>
            </formElements>
        </field>
        <field name="banner_link" sortOrder="60" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">slider</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Banner Link URL</label>
                <dataScope>banner_link</dataScope>
            </settings>
        </field>
        <field name="product_skus" sortOrder="70" formElement="textarea">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">slider</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Product SKUs</label>
                <dataScope>product_skus</dataScope>
                <notice translate="true">Enter product SKUs separated by commas (e.g., SKU001, SKU002, SKU003)</notice>
            </settings>
            <formElements>
                <textarea>
                    <settings>
                        <rows>5</rows>
                    </settings>
                </textarea>
            </formElements>
        </field>
        <field name="layout_position" sortOrder="75" formElement="select">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">slider</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Layout Position</label>
                <dataScope>layout_position</dataScope>
                <notice translate="true">Choose whether the banner/title column appears on the left or right side</notice>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="0" xsi:type="array">
                                <item name="value" xsi:type="string">left</item>
                                <item name="label" xsi:type="string" translate="true">Left (Banner on Left, Products on Right)</item>
                            </option>
                            <option name="1" xsi:type="array">
                                <item name="value" xsi:type="string">right</item>
                                <item name="label" xsi:type="string" translate="true">Right (Products on Left, Banner on Right)</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="sort_order" sortOrder="80" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">slider</item>
                </item>
            </argument>
            <settings>
                <validation>
                    <rule name="validate-number" xsi:type="boolean">true</rule>
                </validation>
                <dataType>text</dataType>
                <label translate="true">Sort Order</label>
                <dataScope>sort_order</dataScope>
            </settings>
        </field>
    </fieldset>
</form>
