<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="topocentras_slider" resource="default" engine="innodb" comment="Topocentras Slider Table">
        <column xsi:type="int" name="slide_id" unsigned="true" nullable="false" identity="true" comment="Slide ID"/>
        <column xsi:type="varchar" name="title" nullable="false" length="255" comment="Slide Title"/>
        <column xsi:type="varchar" name="image" nullable="true" length="255" comment="Image Path"/>
        <column xsi:type="varchar" name="url" nullable="true" length="255" comment="Link URL"/>
        <column xsi:type="int" name="sort_order" unsigned="true" nullable="false" default="0" comment="Sort Order"/>
        <column xsi:type="smallint" name="is_active" unsigned="true" nullable="false" default="1" comment="Is Active"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="slide_id"/>
        </constraint>
        <index referenceId="TOPOCENTRAS_SLIDER_SORT_ORDER" indexType="btree">
            <column name="sort_order"/>
        </index>
        <index referenceId="TOPOCENTRAS_SLIDER_IS_ACTIVE" indexType="btree">
            <column name="is_active"/>
        </index>
    </table>
</schema>
